# ============================================================
# SGI - Variables de Entorno (ejemplo)
# Copiar a .env.local y completar con valores reales
# NUNCA commitear .env.local ni .env.production
# ============================================================

# URL de la Web App de Google Apps Script
VITE_GAS_API_URL=https://script.google.com/macros/s/TU_DEPLOYMENT_ID/exec

# Nombre y versión de la aplicación
VITE_APP_NAME=SGI - Gestión de Inventarios
VITE_APP_VERSION=1.1.0

# URL base para los códigos QR (dominio de producción)
VITE_QR_BASE_URL=https://sgi.tudominio.com
